# Environment Configuration Template for Service Monitor Telegram Bot
# Copy this file to .env and fill in your actual values
# This file contains all required environment variables with examples and documentation

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Path to main YAML configuration file
# Purpose: Loads the primary YAML config containing telegram settings, services,
#          and message templates. Also used as fallback for the default storage
#          backend DSN when STORAGE__DSN is not set.
# Format: File path
# Example: ./configs/config.yml
# Example: /etc/service-monitor/config.yml
CONFIG_PATH=./configs/config.yml

# Development logging mode
# Purpose: When enabled, uses human-readable console output with debug-level
#          verbosity instead of production JSON logging
# Format: Boolean (1|true|TRUE)
# Default: false (production JSON logging)
# Example: 1
# DEBUG=1

# =============================================================================
# HTTP SERVER CONFIGURATION
# =============================================================================

# HTTP server bind address
# Purpose: TCP address for the health check and metrics HTTP server
# Format: host:port
# Default: 127.0.0.1:3000
# Example: 0.0.0.0:3000
# Example: :8080
HTTP__ADDRESS=127.0.0.1:3000

# Trusted proxy header
# Purpose: HTTP header used to determine the real client IP when behind a
#          reverse proxy (e.g., nginx, Cloudflare)
# Format: Header name
# Default: X-Forwarded-For
# Example: X-Real-IP
# HTTP__PROXY_HEADER=X-Forwarded-For

# Trusted proxy IP addresses
# Purpose: List of IP addresses or CIDR ranges of trusted proxies that are
#          allowed to set the proxy header
# Format: Comma-separated list of IP addresses or CIDR ranges
# Default: (empty — all proxies trusted)
# Example: 10.0.0.0/8,192.168.1.0/24
# HTTP__PROXIES=

# OpenAPI documentation endpoint
# Purpose: Enables or disables the Swagger/OpenAPI documentation endpoint
# Format: Boolean (true|false)
# Default: true
# Example: false
# HTTP__OPENAPI__ENABLED=true

# OpenAPI public hostname
# Purpose: Public-facing hostname used in the OpenAPI specification
# Format: Hostname
# Default: (empty — uses request host)
# Example: api.example.com
# HTTP__OPENAPI__PUBLIC_HOST=

# OpenAPI public path prefix
# Purpose: Path prefix for the OpenAPI documentation endpoint
# Format: URL path
# Default: (empty)
# Example: /docs
# HTTP__OPENAPI__PUBLIC_PATH=

# =============================================================================
# TELEGRAM CONFIGURATION
# =============================================================================

# Telegram Bot API token
# Purpose: Authentication token for the Telegram Bot API. Required for the bot
#          to connect to Telegram and receive/send messages
# Format: Telegram bot token (digits:alphanumeric)
# Required: Yes — the app will fail to start without it
# Example: 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM__TOKEN=your-bot-token

# Telegram notification chat ID
# Purpose: Target chat, group, or channel where the bot sends service status
#          notifications. Negative IDs indicate groups or channels
# Format: Integer (positive for user chats, negative for groups/channels)
# Example: 123456789
# Example: -1001234567890
TELEGRAM__CHATID=-1234567890123

# SOCKS5 proxy for Telegram API
# Purpose: SOCKS5 proxy URL for connecting to the Telegram API. Useful when
#          the server is behind a restrictive network that blocks Telegram
# Format: SOCKS5 URL
# Example: socks5://user:password@127.0.0.1:1080
# TELEGRAM__PROXY_URL=

# Telegram API client timeout
# Purpose: Timeout for HTTP requests to the Telegram Bot API
# Format: Duration (Go time.Duration format)
# Default: 1m
# Example: 30s
# Example: 5m
# TELEGRAM__TIMEOUT=1m

# Custom message templates
# Purpose: Override built-in notification templates for online, offline, and
#          services list messages. Keys: online, offline, services_list
# Format: JSON object with template strings
# Default: (built-in defaults are used if not set)
# Example: {"online":"✅ {{.Name}} is *online*","offline":"❌ {{.Name}} is *offline*: {{.Error}}"}
# TELEGRAM__MESSAGES={"online":"\u2705 {{.Name}} is *online*","offline":"\u274c {{.Name}} is *offline*: {{.Error}}"}

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================

# Storage backend DSN
# Purpose: Data Source Name for the monitored services storage backend.
#          Controls where the service list is loaded from.
#          Supported schemes:
#            file  — YAML file on disk (default, uses CONFIG_PATH as fallback)
#            redis — Redis key/value storage
# Format: URL
# Default: file://$CONFIG_PATH (derived from CONFIG_PATH)
# Example: file://./configs/services.yml
# Example: redis://localhost:6379/0?key=service-monitor:services&channel=service-monitor:reload
# Example: redis://:password@redis.example.com:6379/1?key=my-services
# STORAGE__DSN=file://./configs/services.yml
